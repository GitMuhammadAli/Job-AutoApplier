generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // Runtime queries use the pooled (PgBouncer) URL.
  url       = env("DATABASE_URL")
  // Migrations + introspection use the direct (unpooled) URL. PgBouncer
  // pooled connections can't reliably support session-level features like
  // `pg_advisory_lock`, which Prisma migrate requires. See
  // https://pris.ly/d/migrate-advisory-locking.
  // If DIRECT_URL is not set, scripts/migrate-prod.mjs derives it from
  // DATABASE_URL by stripping "-pooler" (standard Neon convention).
  directUrl = env("DIRECT_URL")
}

// ── AUTH (NextAuth) ──

model User {
  id                String             @id @default(cuid())
  name              String?
  email             String?            @unique
  emailVerified     DateTime?
  image             String?
  accounts          Account[]
  sessions          Session[]
  userJobs              UserJob[]
  resumes               Resume[]
  // Resume generator — flat (no ResumeProfile hub). Header lives on UserSettings + User.
  resumeSummaries       ResumeSummary[]
  resumeExperiences     ResumeExperience[]
  resumeProjects        ResumeProject[]
  resumeEducation       ResumeEducation[]
  resumeCertifications  ResumeCertification[]
  resumeGenerations     ResumeGeneration[]
  settings              UserSettings?
  activities        Activity[]
  applications      JobApplication[]
  feedback          UserFeedback[]
  pushSubscriptions PushSubscription[]
  tokenUsage        TokenUsage[]
  llmCalls          LlmCallLog[]
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ── GLOBAL JOB ──

model GlobalJob {
  id              String    @id @default(cuid())
  title           String
  company         String
  location        String?
  description     String?   @db.Text
  salary          String?
  jobType         String?
  experienceLevel String?
  category        String?
  skills          String[]
  postedDate      DateTime?
  expiryDate      DateTime?
  source          String
  sourceId        String
  sourceUrl       String?
  applyUrl        String?
  companyUrl      String?
  companyEmail        String?
  emailSource        String?
  emailConfidence    Int?
  emailContributedBy String?
  isActive          Boolean   @default(true)
  isFresh         Boolean   @default(true)
  firstSeenAt     DateTime  @default(now())
  lastSeenAt      DateTime  @default(now())
  userJobs        UserJob[]
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([sourceId, source])
  @@index([source])
  @@index([source, isActive])
  @@index([category])
  @@index([isActive, createdAt])
  @@index([isFresh, isActive])
  @@index([createdAt])
}

// ── COMPANY EMAIL CACHE ──

model CompanyEmail {
  id             String   @id @default(cuid())
  companyNorm    String   @unique
  companyDisplay String
  email          String
  confidence     Int
  source         String
  lastVerifiedAt DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([companyNorm])
}

// ── USER JOB ──

model UserJob {
  id             String         @id @default(cuid())
  userId         String
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  globalJobId    String
  globalJob      GlobalJob      @relation(fields: [globalJobId], references: [id], onDelete: Cascade)
  stage          JobStage       @default(SAVED)
  matchScore     Float?
  matchReasons   String[]
  notes          String?        @db.Text
  coverLetter    String?        @db.Text
  isBookmarked   Boolean        @default(false)
  isDismissed    Boolean        @default(false)
  dismissReason  String?
  // Snooze a job for N days — middle ground between Save (forever) and
  // Dismiss (permanent). Job is hidden from /recommended until this date
  // passes, then auto-reappears so the user can revisit when they're ready.
  // null = not snoozed.
  snoozedUntil   DateTime?
  lastFollowUpAt DateTime?
  followUpCount  Int            @default(0)
  activities     Activity[]
  application    JobApplication?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@unique([userId, globalJobId])
  @@index([userId, stage])
  @@index([userId, matchScore])
  @@index([userId, isDismissed])
  @@index([userId, snoozedUntil])
  @@index([userId, createdAt])
}

enum JobStage {
  SAVED
  APPLIED
  INTERVIEW
  OFFER
  REJECTED
  GHOSTED
}

// ── RESUME ──

model Resume {
  id               String           @id @default(cuid())
  userId           String
  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  name             String
  fileName         String?
  fileUrl          String?
  fileType         String?
  content          String?          @db.Text
  textQuality      String?          @default("good")
  targetCategories String[]
  detectedSkills   String[]
  isDefault        Boolean          @default(false)
  isDeleted        Boolean          @default(false)
  deletedAt        DateTime?
  applications     JobApplication[]
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  @@index([userId])
  @@index([userId, isDeleted])
}

// ── USER SETTINGS ──

model UserSettings {
  id                       String          @id @default(cuid())
  userId                   String          @unique
  user                     User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Personal
  fullName                 String?
  phone                    String?
  linkedinUrl              String?
  portfolioUrl             String?
  githubUrl                String?
  // Job Preferences
  keywords                 String[]
  negativeKeywords         String[]
  city                     String?
  country                  String?
  salaryMin                Int?
  salaryMax                Int?
  salaryCurrency           String?         @default("USD")
  experienceLevel          String?
  education                String?
  workType                 String[]
  jobType                  String[]
  languages                String[]
  preferredCategories      String[]
  preferredPlatforms       String[]
  // Notifications
  emailNotifications       Boolean         @default(true)
  pushNotifications        Boolean         @default(false)
  notificationEmail        String?
  // Email Provider
  emailProvider            String?         @default("brevo")
  smtpHost                 String?
  smtpPort                 Int?
  smtpUser                 String?
  smtpPass                 String?
  // Application Automation
  applicationEmail         String?
  // Default = MANUAL: new users skip the SMTP setup gauntlet entirely.
  // Tool is useful on day 1 (job discovery, ATS forms via "Open apply page",
  // application tracking) without requiring Gmail app password / SMTP host
  // / email warmup. Users who want auto-email-send can opt in via Settings.
  applicationMode          ApplicationMode @default(MANUAL)
  autoApplyEnabled         Boolean         @default(false)
  instantApplyEnabled      Boolean         @default(false)
  maxAutoApplyPerDay       Int             @default(10)
  minMatchScoreForAutoApply Float          @default(75.0)
  defaultSignature         String?         @db.Text
  priorityPlatforms        String[]
  peakHoursOnly            Boolean         @default(false)
  timezone                 String?         @default("Asia/Karachi")
  // Resume Matching
  resumeMatchMode          String?         @default("smart")
  // AI Customization
  customSystemPrompt       String?         @db.Text
  preferredTone            String?         @default("professional")
  emailLanguage            String?         @default("English")
  includeLinkedin          Boolean         @default(true)
  includeGithub            Boolean         @default(true)
  includePortfolio         Boolean         @default(true)
  customClosing            String?
  // Account & Notifications
  accountStatus            String?         @default("active")
  notificationFrequency    String?         @default("hourly")
  instantApplyDelay        Int?            @default(5)
  // Sending Safety
  sendDelaySeconds         Int             @default(120)
  maxSendsPerHour          Int             @default(8)
  maxSendsPerDay           Int             @default(20)
  cooldownMinutes          Int             @default(30)
  bouncePauseHours         Int             @default(24)
  sendingPausedUntil       DateTime?
  smtpVerifiedAt           DateTime?
  smtpSetupDate            DateTime?
  // Company Blacklist
  blacklistedCompanies     String[]
  // Resume Generator (Phase 1 — header lives here, sections in dedicated tables)
  resumeHeadline           String?         // e.g. "Software Engineer — Full Stack"
  resumeSkills             String[]        @default([])  // master skill list, ordering is user-default
  resumeSkillsLocked       Boolean         @default(false) // once onboarded, JD tailoring won't fabricate new skills
  // User Tracking
  lastVisitedAt            DateTime?
  // Relations & State
  emailTemplates           EmailTemplate[]
  isOnboarded              Boolean         @default(false)
  createdAt                DateTime        @default(now())
  updatedAt                DateTime        @updatedAt
}

enum ApplicationMode {
  MANUAL
  SEMI_AUTO
  FULL_AUTO
  INSTANT
}

// ── EMAIL TEMPLATE ──

model EmailTemplate {
  id         String       @id @default(cuid())
  userId     String
  settingsId String
  settings   UserSettings @relation(fields: [settingsId], references: [id], onDelete: Cascade)
  name       String
  subject    String
  body       String       @db.Text
  isDefault  Boolean      @default(false)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  @@index([userId])
  @@index([userId, isDefault])
}

// ── JOB APPLICATION ──

model JobApplication {
  id              String            @id @default(cuid())
  userJobId       String            @unique
  userJob         UserJob           @relation(fields: [userJobId], references: [id], onDelete: Cascade)
  userId          String
  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  senderEmail     String
  recipientEmail  String
  subject         String
  emailBody       String            @db.Text
  resumeId        String?
  resume          Resume?           @relation(fields: [resumeId], references: [id])
  // Nullable forward-compat for the resume generator. Phase 3 will populate
  // this when auto-apply renders a fresh PDF; Phase 1 leaves it null.
  resumeGenerationId String?
  resumeGeneration   ResumeGeneration? @relation(fields: [resumeGenerationId], references: [id], onDelete: SetNull)
  coverLetter     String?           @db.Text
  templateId      String?
  status          ApplicationStatus @default(DRAFT)
  sentAt          DateTime?
  errorMessage    String?
  retryCount      Int               @default(0)
  appliedVia      ApplyMethod       @default(EMAIL)
  emailConfidence String?
  scheduledSendAt  DateTime?
  followUpSubject  String?
  followUpBody     String?           @db.Text
  followUpStatus   String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@index([userId, status])
  @@index([userId, createdAt])
  @@index([status, scheduledSendAt])
  @@index([userId, sentAt])
}

enum ApplicationStatus {
  DRAFT
  READY
  SENDING
  SENT
  FAILED
  BOUNCED
  CANCELLED
}

enum ApplyMethod {
  EMAIL
  MANUAL
  PLATFORM
}

// ── ACTIVITY TIMELINE ──

model Activity {
  id        String       @id @default(cuid())
  userJobId String?
  userJob   UserJob?     @relation(fields: [userJobId], references: [id], onDelete: Cascade)
  userId    String
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      ActivityType
  description String
  createdAt DateTime     @default(now())

  @@index([userJobId])
  @@index([userId, createdAt])
  @@index([userId, type, createdAt])
}

enum ActivityType {
  STAGE_CHANGE
  NOTE_ADDED
  COVER_LETTER_GENERATED
  APPLICATION_PREPARED
  APPLICATION_SENT
  APPLICATION_FAILED
  APPLICATION_BOUNCED
  APPLICATION_CANCELLED
  APPLICATION_COPIED
  FOLLOW_UP_SENT
  FOLLOW_UP_FLAGGED
  MANUAL_UPDATE
  DISMISSED
  NOTIFICATION_SENT
}

// ── SYSTEM ──

model SystemLock {
  name        String    @id
  isRunning   Boolean   @default(false)
  startedAt   DateTime?
  completedAt DateTime?
}

model SystemLog {
  id        String   @id @default(cuid())
  type      String
  source    String?
  message   String
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([type, createdAt])
  @@index([source, createdAt])
  @@index([type, source])
}

// ── SCRAPER RUN ──

model ScraperRun {
  id           String   @id @default(cuid())
  source       String
  status       String   @default("running") // running, success, partial, failed, timeout, skipped
  jobsFound    Int      @default(0)
  jobsSaved    Int      @default(0)
  errorMessage String?  @db.Text
  durationMs   Int?
  query        String?
  startedAt    DateTime @default(now())
  completedAt  DateTime?

  @@index([source, startedAt])
  @@index([status, startedAt])
}

// ── PUSH SUBSCRIPTION ──

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String   @db.Text
  p256dh    String
  auth      String
  userAgent String?
  createdAt DateTime @default(now())

  @@unique([userId, endpoint])
  @@index([userId])
}

// ── USER FEEDBACK ──

model UserFeedback {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String   // "bug" | "suggestion" | "compliment" | "other"
  message   String   @db.Text
  page      String?
  status    String   @default("new") // "new" | "reviewed" | "resolved" | "dismissed"
  adminNote String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, createdAt])
  @@index([status, createdAt])
}

// ──────────────────────────────────────────────────────────────────────────
// RESUME GENERATOR
//
// Flat layout: NO ResumeProfile hub. Header lives on UserSettings + User.
// Body sections (Summary/Experience/Project/Education/Certification) hang
// directly off User via userId. Saved-variant concept folded into
// ResumeGeneration.{name,isFavorite} — no separate ResumeVariant table.
//
// Hard rule across all of them: AI only reorders / selects from items the
// user has entered. It never rewrites bullets, titles, dates, or company
// names. See docs/resume-generator-design.md for the full contract.
// ──────────────────────────────────────────────────────────────────────────

model ResumeSummary {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  label       String   // "MERN-leaning", "AI-eval-leaning"
  content     String   @db.Text
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
}

model ResumeExperience {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  company     String
  title       String
  location    String?
  startDate   String   // "August 2025" — display verbatim, NOT Date (preserves user format)
  endDate     String?  // "Present" or "August 2025"
  bullets     String[] // 2–6 bullets per job. ORDER matters; AI may reorder within a job. Each ≤ 280 chars (Zod-enforced).

  order       Int      // user's authored order; default render order
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId, order])
}

model ResumeProject {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  title       String
  role        String?  // "Solo", "Lead", "Contributor"
  oneLiner    String   // single-line description shown when collapsed
  bullets     String[] // 2–4 bullets, immutable from AI's side
  stack       String[] // tech tags — used to score project relevance per JD
  liveUrl     String?
  repoUrl     String?

  isFeatured  Boolean  @default(false)  // "always include if room"
  order       Int

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId, order])
  @@index([userId, isFeatured])
}

model ResumeEducation {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  institution String
  degree      String
  startDate   String?
  endDate     String?
  details     String?  @db.Text
  order       Int
  createdAt   DateTime @default(now())

  @@index([userId, order])
}

model ResumeCertification {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  name          String
  issuer        String?
  issuedDate    String?
  credentialUrl String?
  order         Int
  createdAt     DateTime @default(now())

  @@index([userId, order])
}

// A single rendered output. Persists for audit + re-download.
// Stream-on-demand: PDFs are rendered from `htmlSnapshot` each time the user
// downloads. We never store the binary PDF in v1. `templateVersion` is pinned
// so the regenerated PDF is byte-identical to what the user saw originally.
//
// `name` + `isFavorite` replace the dropped ResumeVariant model — saving a
// "variant" is just naming a generation and marking it favorite.
model ResumeGeneration {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  templateId      String
  templateVersion String   // pinned at generation time
  pageTarget      Int
  pdfUrl          String?  // unused in v1 (stream-on-demand). Reserved for future "saved PDF" path.
  htmlSnapshot    String?  @db.Text  // canonical artifact — regen reads this
  jdSnippet       String?  @db.Text
  matchedKeywords String[] // for the diff-preview sidebar

  // Variant-as-row: name + isFavorite let a generation act as a saved variant
  // without a separate table.
  name            String?  // user-given label, e.g. "AI-eval-leaning"
  isFavorite      Boolean  @default(false)

  applications    JobApplication[]

  createdAt       DateTime @default(now())

  @@index([userId, createdAt])
  @@index([userId, isFavorite])
}

// ── TOKEN QUOTA ──────────────────────────────────────────────────────
// Fair-share token accounting per (user, day, provider). See
// qa-run-20260522/TOKEN_QUOTA_ARCHITECTURE.md for the design rationale.

model TokenUsage {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  day           DateTime @db.Date         // UTC midnight to midnight rollup
  provider      String                    // "groq" | "gemini" | "anthropic"
  inputTokens   Int      @default(0)
  outputTokens  Int      @default(0)
  totalCalls    Int      @default(0)
  rejectedCalls Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([userId, day, provider])
  @@index([day, provider])
}

// Per-call log — feeds hourly trend chart + per-route breakdown in /admin/quotas.
// Daily aggregation lives in TokenUsage; prune LlmCallLog after 30d via cron.
model LlmCallLog {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider     String
  model        String                     // "llama-3.1-8b-instant" etc
  route        String                     // "/api/resumes/generate"
  inputTokens  Int
  outputTokens Int
  latencyMs    Int
  status       String                     // "ok" | "rejected_quota" | "rejected_global" | "error"
  errorMessage String?
  createdAt    DateTime @default(now())

  @@index([userId, createdAt])
  @@index([route, createdAt])
  @@index([status, createdAt])
}

// Runtime-tunable quota knobs. Singleton-per-provider.
model QuotaConfig {
  id          String   @id @default(cuid())
  provider    String   @unique             // "groq" | "gemini" | "anthropic"
  dailyBudget Int                          // total tokens/day across all users
  softCapMult Float    @default(2.0)       // user fair-share multiplier (allows 1 user to consume more when others dormant)
  enabled     Boolean  @default(true)
  updatedAt   DateTime @updatedAt
}
