generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── AUTH (NextAuth) ──

model User {
  id                String             @id @default(cuid())
  name              String?
  email             String?            @unique
  emailVerified     DateTime?
  image             String?
  accounts          Account[]
  sessions          Session[]
  userJobs          UserJob[]
  resumes           Resume[]
  resumeProfile     ResumeProfile?
  settings          UserSettings?
  activities        Activity[]
  applications      JobApplication[]
  feedback          UserFeedback[]
  pushSubscriptions PushSubscription[]
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ── GLOBAL JOB ──

model GlobalJob {
  id              String    @id @default(cuid())
  title           String
  company         String
  location        String?
  description     String?   @db.Text
  salary          String?
  jobType         String?
  experienceLevel String?
  category        String?
  skills          String[]
  postedDate      DateTime?
  expiryDate      DateTime?
  source          String
  sourceId        String
  sourceUrl       String?
  applyUrl        String?
  companyUrl      String?
  companyEmail        String?
  emailSource        String?
  emailConfidence    Int?
  emailContributedBy String?
  isActive          Boolean   @default(true)
  isFresh         Boolean   @default(true)
  firstSeenAt     DateTime  @default(now())
  lastSeenAt      DateTime  @default(now())
  userJobs        UserJob[]
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([sourceId, source])
  @@index([source])
  @@index([source, isActive])
  @@index([category])
  @@index([isActive, createdAt])
  @@index([isFresh, isActive])
  @@index([createdAt])
}

// ── COMPANY EMAIL CACHE ──

model CompanyEmail {
  id             String   @id @default(cuid())
  companyNorm    String   @unique
  companyDisplay String
  email          String
  confidence     Int
  source         String
  lastVerifiedAt DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([companyNorm])
}

// ── USER JOB ──

model UserJob {
  id             String         @id @default(cuid())
  userId         String
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  globalJobId    String
  globalJob      GlobalJob      @relation(fields: [globalJobId], references: [id], onDelete: Cascade)
  stage          JobStage       @default(SAVED)
  matchScore     Float?
  matchReasons   String[]
  notes          String?        @db.Text
  coverLetter    String?        @db.Text
  isBookmarked   Boolean        @default(false)
  isDismissed    Boolean        @default(false)
  dismissReason  String?
  lastFollowUpAt DateTime?
  followUpCount  Int            @default(0)
  activities     Activity[]
  application    JobApplication?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@unique([userId, globalJobId])
  @@index([userId, stage])
  @@index([userId, matchScore])
  @@index([userId, isDismissed])
  @@index([userId, createdAt])
}

enum JobStage {
  SAVED
  APPLIED
  INTERVIEW
  OFFER
  REJECTED
  GHOSTED
}

// ── RESUME ──

model Resume {
  id               String           @id @default(cuid())
  userId           String
  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  name             String
  fileName         String?
  fileUrl          String?
  fileType         String?
  content          String?          @db.Text
  textQuality      String?          @default("good")
  targetCategories String[]
  detectedSkills   String[]
  isDefault        Boolean          @default(false)
  isDeleted        Boolean          @default(false)
  deletedAt        DateTime?
  applications     JobApplication[]
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  @@index([userId])
  @@index([userId, isDeleted])
}

// ── USER SETTINGS ──

model UserSettings {
  id                       String          @id @default(cuid())
  userId                   String          @unique
  user                     User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Personal
  fullName                 String?
  phone                    String?
  linkedinUrl              String?
  portfolioUrl             String?
  githubUrl                String?
  // Job Preferences
  keywords                 String[]
  negativeKeywords         String[]
  city                     String?
  country                  String?
  salaryMin                Int?
  salaryMax                Int?
  salaryCurrency           String?         @default("USD")
  experienceLevel          String?
  education                String?
  workType                 String[]
  jobType                  String[]
  languages                String[]
  preferredCategories      String[]
  preferredPlatforms       String[]
  // Notifications
  emailNotifications       Boolean         @default(true)
  pushNotifications        Boolean         @default(false)
  notificationEmail        String?
  // Email Provider
  emailProvider            String?         @default("brevo")
  smtpHost                 String?
  smtpPort                 Int?
  smtpUser                 String?
  smtpPass                 String?
  // Application Automation
  applicationEmail         String?
  // Default = MANUAL: new users skip the SMTP setup gauntlet entirely.
  // Tool is useful on day 1 (job discovery, ATS forms via "Open apply page",
  // application tracking) without requiring Gmail app password / SMTP host
  // / email warmup. Users who want auto-email-send can opt in via Settings.
  applicationMode          ApplicationMode @default(MANUAL)
  autoApplyEnabled         Boolean         @default(false)
  instantApplyEnabled      Boolean         @default(false)
  maxAutoApplyPerDay       Int             @default(10)
  minMatchScoreForAutoApply Float          @default(75.0)
  defaultSignature         String?         @db.Text
  priorityPlatforms        String[]
  peakHoursOnly            Boolean         @default(false)
  timezone                 String?         @default("Asia/Karachi")
  // Resume Matching
  resumeMatchMode          String?         @default("smart")
  // AI Customization
  customSystemPrompt       String?         @db.Text
  preferredTone            String?         @default("professional")
  emailLanguage            String?         @default("English")
  includeLinkedin          Boolean         @default(true)
  includeGithub            Boolean         @default(true)
  includePortfolio         Boolean         @default(true)
  customClosing            String?
  // Account & Notifications
  accountStatus            String?         @default("active")
  notificationFrequency    String?         @default("hourly")
  instantApplyDelay        Int?            @default(5)
  // Sending Safety
  sendDelaySeconds         Int             @default(120)
  maxSendsPerHour          Int             @default(8)
  maxSendsPerDay           Int             @default(20)
  cooldownMinutes          Int             @default(30)
  bouncePauseHours         Int             @default(24)
  sendingPausedUntil       DateTime?
  smtpVerifiedAt           DateTime?
  smtpSetupDate            DateTime?
  // Company Blacklist
  blacklistedCompanies     String[]
  // User Tracking
  lastVisitedAt            DateTime?
  // Relations & State
  emailTemplates           EmailTemplate[]
  isOnboarded              Boolean         @default(false)
  createdAt                DateTime        @default(now())
  updatedAt                DateTime        @updatedAt
}

enum ApplicationMode {
  MANUAL
  SEMI_AUTO
  FULL_AUTO
  INSTANT
}

// ── EMAIL TEMPLATE ──

model EmailTemplate {
  id         String       @id @default(cuid())
  userId     String
  settingsId String
  settings   UserSettings @relation(fields: [settingsId], references: [id], onDelete: Cascade)
  name       String
  subject    String
  body       String       @db.Text
  isDefault  Boolean      @default(false)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  @@index([userId])
  @@index([userId, isDefault])
}

// ── JOB APPLICATION ──

model JobApplication {
  id              String            @id @default(cuid())
  userJobId       String            @unique
  userJob         UserJob           @relation(fields: [userJobId], references: [id], onDelete: Cascade)
  userId          String
  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  senderEmail     String
  recipientEmail  String
  subject         String
  emailBody       String            @db.Text
  resumeId        String?
  resume          Resume?           @relation(fields: [resumeId], references: [id])
  // Nullable forward-compat for the resume generator. Phase 3 will populate
  // this when auto-apply renders a fresh PDF; Phase 1 leaves it null.
  resumeGenerationId String?
  resumeGeneration   ResumeGeneration? @relation(fields: [resumeGenerationId], references: [id], onDelete: SetNull)
  coverLetter     String?           @db.Text
  templateId      String?
  status          ApplicationStatus @default(DRAFT)
  sentAt          DateTime?
  errorMessage    String?
  retryCount      Int               @default(0)
  appliedVia      ApplyMethod       @default(EMAIL)
  emailConfidence String?
  scheduledSendAt  DateTime?
  followUpSubject  String?
  followUpBody     String?           @db.Text
  followUpStatus   String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@index([userId, status])
  @@index([userId, createdAt])
  @@index([status, scheduledSendAt])
  @@index([userId, sentAt])
}

enum ApplicationStatus {
  DRAFT
  READY
  SENDING
  SENT
  FAILED
  BOUNCED
  CANCELLED
}

enum ApplyMethod {
  EMAIL
  MANUAL
  PLATFORM
}

// ── ACTIVITY TIMELINE ──

model Activity {
  id        String       @id @default(cuid())
  userJobId String?
  userJob   UserJob?     @relation(fields: [userJobId], references: [id], onDelete: Cascade)
  userId    String
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      ActivityType
  description String
  createdAt DateTime     @default(now())

  @@index([userJobId])
  @@index([userId, createdAt])
  @@index([userId, type, createdAt])
}

enum ActivityType {
  STAGE_CHANGE
  NOTE_ADDED
  COVER_LETTER_GENERATED
  APPLICATION_PREPARED
  APPLICATION_SENT
  APPLICATION_FAILED
  APPLICATION_BOUNCED
  APPLICATION_CANCELLED
  APPLICATION_COPIED
  FOLLOW_UP_SENT
  FOLLOW_UP_FLAGGED
  MANUAL_UPDATE
  DISMISSED
  NOTIFICATION_SENT
}

// ── SYSTEM ──

model SystemLock {
  name        String    @id
  isRunning   Boolean   @default(false)
  startedAt   DateTime?
  completedAt DateTime?
}

model SystemLog {
  id        String   @id @default(cuid())
  type      String
  source    String?
  message   String
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([type, createdAt])
  @@index([source, createdAt])
  @@index([type, source])
}

// ── SCRAPER RUN ──

model ScraperRun {
  id           String   @id @default(cuid())
  source       String
  status       String   @default("running") // running, success, partial, failed, timeout, skipped
  jobsFound    Int      @default(0)
  jobsSaved    Int      @default(0)
  errorMessage String?  @db.Text
  durationMs   Int?
  query        String?
  startedAt    DateTime @default(now())
  completedAt  DateTime?

  @@index([source, startedAt])
  @@index([status, startedAt])
}

// ── PUSH SUBSCRIPTION ──

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String   @db.Text
  p256dh    String
  auth      String
  userAgent String?
  createdAt DateTime @default(now())

  @@unique([userId, endpoint])
  @@index([userId])
}

// ── USER FEEDBACK ──

model UserFeedback {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String   // "bug" | "suggestion" | "compliment" | "other"
  message   String   @db.Text
  page      String?
  status    String   @default("new") // "new" | "reviewed" | "resolved" | "dismissed"
  adminNote String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, createdAt])
  @@index([status, createdAt])
}

// ──────────────────────────────────────────────────────────────────────────
// RESUME GENERATOR  (Phase 1)
//
// Eight models that hold a user's structured resume profile and the rendered
// outputs. The hard rule across all of them: AI only reorders / selects from
// items the user has entered. It never rewrites bullets, titles, dates, or
// company names. See docs/resume-generator-design.md for the full contract.
// ──────────────────────────────────────────────────────────────────────────

model ResumeProfile {
  id          String  @id @default(cuid())
  userId      String  @unique
  user        User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Header
  fullName    String
  headline    String   // "Software Engineer — LLM Evaluation & Agentic Systems"
  location    String?
  email       String
  phone       String?
  websiteUrl  String?
  githubUrl   String?
  linkedinUrl String?

  // Master skills — ordering is the DEFAULT order (used when no JD).
  // Once `skillsLocked = true`, JD tailoring rejects skills not in this list
  // instead of silently dropping them — it surfaces an error to the user.
  skills       String[]
  skillsLocked Boolean @default(false)

  summaries      ResumeSummary[]
  experiences    ResumeExperience[]
  projects       ResumeProject[]
  education      ResumeEducation[]
  certifications ResumeCertification[]
  variants       ResumeVariant[]
  generations    ResumeGeneration[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ResumeSummary {
  id          String   @id @default(cuid())
  profileId   String
  profile     ResumeProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  label       String   // "MERN-leaning", "AI-eval-leaning"
  content     String   @db.Text
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([profileId])
}

model ResumeExperience {
  id          String   @id @default(cuid())
  profileId   String
  profile     ResumeProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  company     String
  title       String
  location    String?
  startDate   String   // "August 2025" — display verbatim, NOT Date (preserves user format)
  endDate     String?  // "Present" or "August 2025"
  bullets     String[] // 2–6 bullets per job. ORDER matters; AI may reorder within a job. Each ≤ 280 chars (Zod-enforced).

  order       Int      // user's authored order; default render order
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([profileId, order])
}

model ResumeProject {
  id          String   @id @default(cuid())
  profileId   String
  profile     ResumeProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  title       String
  role        String?  // "Solo", "Lead", "Contributor"
  oneLiner    String   // single-line description shown when collapsed
  bullets     String[] // 2–4 bullets, immutable from AI's side
  stack       String[] // tech tags — used to score project relevance per JD
  liveUrl     String?
  repoUrl     String?

  isFeatured  Boolean  @default(false)  // "always include if room"
  order       Int

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([profileId, order])
  @@index([profileId, isFeatured])
}

model ResumeEducation {
  id          String   @id @default(cuid())
  profileId   String
  profile     ResumeProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  institution String
  degree      String
  startDate   String?
  endDate     String?
  details     String?  @db.Text
  order       Int
  createdAt   DateTime @default(now())

  @@index([profileId, order])
}

model ResumeCertification {
  id            String   @id @default(cuid())
  profileId     String
  profile       ResumeProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  name          String
  issuer        String?
  issuedDate    String?
  credentialUrl String?
  order         Int
  createdAt     DateTime @default(now())

  @@index([profileId, order])
}

// A named saved tailoring. User can save the result of a JD-driven generation
// as a reusable variant ("AI-eval-leaning", "Backend-leaning", etc.).
model ResumeVariant {
  id              String   @id @default(cuid())
  profileId       String
  profile         ResumeProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  name            String
  templateId      String   // "T01" | "T02" | ... from the template registry
  templateVersion String   // "T01@1.0.0" — pinned so future CSS tweaks don't silently rewrite history
  pageTarget      Int      @default(1)

  // Ordering / selection — the ONLY knobs the AI / user can change.
  skillsOrder     String[] // ordered subset of profile.skills
  projectIds      String[] // ordered subset of profile.projects
  experienceIds   String[] // ordered subset of profile.experiences
  summaryId       String?  // which ResumeSummary
  sectionOrder    String[] // ["summary", "skills", "experience", "projects", "education"]

  isDefault       Boolean  @default(false)
  generatedFromJd Boolean  @default(false)
  jdSnippet       String?  @db.Text

  generations     ResumeGeneration[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([profileId])
}

// A single rendered output. Persists for audit + re-download.
// Stream-on-demand: PDFs are rendered from `htmlSnapshot` each time the user
// downloads. We never store the binary PDF in v1. `templateVersion` is pinned
// so the regenerated PDF is byte-identical to what the user saw originally.
model ResumeGeneration {
  id              String   @id @default(cuid())
  profileId       String
  profile         ResumeProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  variantId       String?
  variant         ResumeVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  templateId      String
  templateVersion String   // pinned at generation time
  pageTarget      Int
  pdfUrl          String?  // unused in v1 (stream-on-demand). Reserved for future "saved PDF" path.
  htmlSnapshot    String?  @db.Text  // canonical artifact — regen reads this
  jdSnippet       String?  @db.Text
  matchedKeywords String[] // for the diff-preview sidebar

  applications    JobApplication[]

  createdAt       DateTime @default(now())

  @@index([profileId, createdAt])
}
